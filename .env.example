# Inference Script Environment Variables
# ========================================

# The API endpoint for the LLM
# Default: http://127.0.0.1:8000 (local FastAPI backend)
API_BASE_URL=http://127.0.0.1:8000

# The model identifier to use for inference
# Default: gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# Your Hugging Face / API key (MANDATORY)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# The name of the local Docker image to use
# Used for from_docker_image() method if applicable
LOCAL_IMAGE_NAME=crime-intelligence-api
